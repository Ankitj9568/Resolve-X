# ────────────────────────────────────────────────────────────────────────────
# ResolveX Classification Service — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ────────────────────────────────────────────────────────────────────────────

# ── Required ─────────────────────────────────────────────────────────────────
# Your NVIDIA NIM API key (get it from https://build.nvidia.com)
NIM_API_KEY=

# ── Optional (defaults shown) ─────────────────────────────────────────────────
# NIM OpenAI-compatible base URL
NIM_BASE_URL=https://integrate.api.nvidia.com/v1

# Model slug — check https://build.nvidia.com/explore/discover for available models
# Text model example (verified with /v1/chat/completions): meta/llama-3.1-8b-instruct
# Some catalog IDs may still return 404 for your key if unavailable.
NIM_MODEL=meta/llama-3.1-8b-instruct

# Vision model example (for requests with image input)
NIM_VISION_MODEL=nvidia/llama-3.1-nemotron-nano-vl-8b-v1

# LLM behaviour
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=1024
LLM_TIMEOUT_SECONDS=30.0
LLM_MAX_RETRIES=2
NIM_DISABLE_REASONING=true

# Service
SERVICE_NAME=ResolveX Classification Service
API_VERSION=v1
LOG_LEVEL=INFO

# Spatial duplicate detection (PostgreSQL + PostGIS)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/resolvex
DB_POOL_MIN_SIZE=1
DB_POOL_MAX_SIZE=10
DB_COMMAND_TIMEOUT_SECONDS=5

# CORS — comma-separated list; use specific origins in production
# CORS_ORIGINS=["https://resolvex.yourdomain.com"]
CORS_ORIGINS=["*"]
